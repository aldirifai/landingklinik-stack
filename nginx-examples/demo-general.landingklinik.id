# /etc/nginx/sites-available/demo-general.landingklinik.id
# Container Docker: demo-general (127.0.0.1:47051)
#
# Setelah enable & reload nginx, run:
#   sudo certbot --nginx -d demo-general.landingklinik.id

server {
	listen 80;
	listen [::]:80;
	server_name demo-general.landingklinik.id;

	access_log /var/log/nginx/demo-general.landingklinik.id.access.log;
	error_log  /var/log/nginx/demo-general.landingklinik.id.error.log;

	location / {
		proxy_pass http://127.0.0.1:47051;
		proxy_http_version 1.1;
		proxy_set_header Upgrade           $http_upgrade;
		proxy_set_header Connection        "upgrade";
		proxy_set_header Host              $host;
		proxy_set_header X-Real-IP         $remote_addr;
		proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_set_header X-Forwarded-Host  $host;
		proxy_cache_bypass $http_upgrade;

		proxy_connect_timeout 30s;
		proxy_send_timeout    60s;
		proxy_read_timeout    60s;
	}
}
